   "source": [
    "from sklearn.metrics import (\n",
    "    classification_report,\n",
    "    confusion_matrix,\n",
    "    ConfusionMatrixDisplay,\n",
    "    accuracy_score,\n",
    "    roc_auc_score,\n",
    "    f1_score,\n",
    "    roc_curve,\n",
    "    precision_recall_curve,\n",
    "    auc\n",
    ")\n",
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# === DICTIONARY MODEL & DATA YANG DIPAKAI ===\n",
    "# Per model kita tentukan X_train/X_test mana yang dipakai\n",
    "model_configs = {\n",
    "    \"XGBoost Saja\": {\n",
    "        \"model\": xgb_sem,\n",
    "        \"X_train\": X_train_sem,\n",
    "        \"X_test\": X_test_sem,\n",
    "    },\n",
    "    \"GNN\": {\n",
    "        \"model\": xgb_gnn,\n",
    "        \"X_train\": X_train_graph,\n",
    "        \"X_test\": X_test_graph,\n",
    "    },\n",
    "    \"Hybrid GNN + XGBoost\": {\n",
    "        \"model\": xgb_hybrid,\n",
    "        \"X_train\": X_train,\n",
    "        \"X_test\": X_test,\n",
    "    },\n",
    "    \"Hybrid Tanpa GraphRAG\": {\n",
    "        \"model\": hybrid_no_rag,    # wrapper tanpa explanation\n",
    "        \"X_train\": X_train,\n",
    "        \"X_test\": X_test,\n",
    "    },\n",
    "    \"Hybrid + GraphRAG (Full)\": {\n",
    "        \"model\": hybrid_full,      # wrapper dengan explanation\n",
    "        \"X_train\": X_train,\n",
    "        \"X_test\": X_test,\n",
    "    },\n",
    "}\n",
    "\n",
    "def evaluate_model_general(name, model, X_train_m, X_test_m, y_train, y_test, pos_label=1):\n",
    "    print(f\"\\n\\n==================== {name} ====================\")\n",
    "\n",
    "    y_pred_train = model.predict(X_train_m)\n",
    "    y_pred_test = model.predict(X_test_m)\n",
    "\n",
    "    # Probabilitas\n",
    "    if hasattr(model, \"predict_proba\"):\n",
    "        y_proba_train = model.predict_proba(X_train_m)[:, 1]\n",
    "        y_proba_test = model.predict_proba(X_test_m)[:, 1]\n",
    "    else:\n",
    "        y_proba_train = y_pred_train\n",
    "        y_proba_test = y_pred_test\n",
    "\n",
    "    # --- Akurasi train & test ---\n",
    "    train_acc = accuracy_score(y_train, y_pred_train)\n",
    "    test_acc = accuracy_score(y_test, y_pred_test)\n",
    "\n",
    "    print(\"=== Evaluasi Overfitting / Underfitting ===\")\n",
    "    print(f\"Akurasi Training : {train_acc:.4f}\")\n",
    "    print(f\"Akurasi Testing  : {test_acc:.4f}\")\n",
    "    if abs(train_acc - test_acc) < 0.03:\n",
    "        print(\"âœ… Model stabil â€” tidak overfitting atau underfitting.\")\n",
    "    elif train_acc > test_acc:\n",
    "        print(\"âš ï¸ Model sedikit overfitting.\")\n",
    "    else:\n",
    "        print(\"âš ï¸ Model underfitting.\")\n",
    "\n",
    "    # --- Distribusi prediksi ---\n",
    "    unique, counts = np.unique(y_pred_test, return_counts=True)\n",
    "    class_dist = dict(zip(unique, counts))\n",
    "    print(\"\\n=== Distribusi Prediksi (Keseimbangan Kelas) ===\")\n",
    "    print(class_dist)\n",
    "\n",
    "    # --- Classification report per kelas ---\n",
    "    report = classification_report(\n",
    "        y_test,\n",
    "        y_pred_test,\n",
    "        target_names=[\"Sensitif (0)\", \"Resisten (1)\"],\n",
    "        output_dict=True\n",
    "    )\n",
    "    print(\"\\n=== Evaluasi Bias Antar Kelas ===\")\n",
    "    for label in [\"Sensitif (0)\", \"Resisten (1)\"]:\n",
    "        prec = report[label][\"precision\"]\n",
    "        rec = report[label][\"recall\"]\n",
    "        f1 = report[label][\"f1-score\"]\n",
    "        print(f\"{label}: Precision={prec:.3f}, Recall={rec:.3f}, F1={f1:.3f}\")\n",
    "\n",
    "    # --- AUC ---\n",
    "    try:\n",
    "        auc_train = roc_auc_score(y_train, y_proba_train)\n",
    "        auc_test = roc_auc_score(y_test, y_proba_test)\n",
    "    except ValueError:\n",
    "        auc_train = np.nan\n",
    "        auc_test = np.nan\n",
    "\n",
    "    print(\"\\n=== Evaluasi Kemampuan Diskriminatif ===\")\n",
    "    print(f\"AUC Train : {auc_train:.4f}\")\n",
    "    print(f\"AUC Test  : {auc_test:.4f}\")\n",
    "\n",
    "    # --- Confusion Matrix ---\n",
    "    cm = confusion_matrix(y_test, y_pred_test)\n",
    "    disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=[0, 1])\n",
    "    disp.plot()\n",
    "    plt.title(f\"Confusion Matrix - {name}\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # --- ROC Curve ---\n",
    "    try:\n",
    "        fpr, tpr, _ = roc_curve(y_test, y_proba_test, pos_label=pos_label)\n",
    "        roc_auc_val = auc(fpr, tpr)\n",
    "\n",
    "        plt.figure()\n",
    "        plt.plot(fpr, tpr, label=f\"AUC = {roc_auc_val:.4f}\")\n",
    "        plt.plot([0, 1], [0, 1], linestyle=\"--\")\n",
    "        plt.xlabel(\"False Positive Rate\")\n",
    "        plt.ylabel(\"True Positive Rate\")\n",
    "        plt.title(f\"ROC Curve - {name}\")\n",
    "        plt.legend(loc=\"lower right\")\n",
    "        plt.tight_layout()\n",
    "        plt.show()\n",
    "    except Exception as e:\n",
    "        print(f\"ROC Curve tidak dapat dihitung: {e}\")\n",
    "\n",
    "    # --- Precision-Recall Curve ---\n",
    "    try:\n",
    "        precision, recall, _ = precision_recall_curve(y_test, y_proba_test, pos_label=pos_label)\n",
    "        pr_auc = auc(recall, precision)\n",
    "\n",
    "        plt.figure()\n",
    "        plt.plot(recall, precision, label=f\"AUC PR = {pr_auc:.4f}\")\n",
    "        plt.xlabel(\"Recall\")\n",
    "        plt.ylabel(\"Precision\")\n",
    "        plt.title(f\"Precision-Recall Curve - {name}\")\n",
    "        plt.legend(loc=\"lower left\")\n",
    "        plt.tight_layout()\n",
    "        plt.show()\n",
    "    except Exception as e:\n",
    "        print(f\"Precision-Recall Curve tidak dapat dihitung: {e}\")\n",
    "\n",
    "    # --- return metrik buat ablation table ---\n",
    "    metrics = {\n",
    "        \"Model\": name,\n",
    "        \"Accuracy Test\": test_acc,\n",
    "        \"F1 Macro\": f1_score(y_test, y_pred_test, average=\"macro\"),\n",
    "        \"F1 Weighted\": f1_score(y_test, y_pred_test, average=\"weighted\"),\n",
    "        \"AUC Test\": auc_test,\n",
    "        \"F1 Sensitif\": report[\"Sensitif (0)\"][\"f1-score\"],\n",
    "        \"F1 Resisten\": report[\"Resisten (1)\"][\"f1-score\"],\n",
    "    }\n",
    "    return metrics\n",
    "\n",
    "# === LOOP SEMUA MODEL â†’ KUMPULKAN METRIK ===\n",
    "results = []\n",
    "for name, cfg in model_configs.items():\n",
    "    m = evaluate_model_general(\n",
    "        name,\n",
    "        cfg[\"model\"],\n",
    "        cfg[\"X_train\"],\n",
    "        cfg[\"X_test\"],\n",
    "        y_train,\n",
    "        y_test\n",
    "    )\n",
    "    results.append(m)\n",
    "\n",
    "# === TABEL ABLATION STUDY ===\n",
    "ablation_df = pd.DataFrame(results)\n",
    "\n",
    "# Kalau mau urutan spesifik di tabel:\n",
    "order = [\n",
    "    \"XGBoost Saja\",\n",
    "    \"GNN\",\n",
    "    \"Hybrid GNN + XGBoost\",\n",
    "    \"Hybrid Tanpa GraphRAG\",\n",
    "    \"Hybrid + GraphRAG (Full)\",\n",
    "]\n",
    "ablation_df[\"order\"] = ablation_df[\"Model\"].apply(lambda x: order.index(x) if x in order else 999)\n",
    "ablation_df = ablation_df.sort_values(\"order\").drop(columns=[\"order\"])\n",
    "\n",
    "print(\"\\n=== TABEL ABLATION STUDY ===\")\n",
    "print(ablation_df)\n"
   ]
  },
