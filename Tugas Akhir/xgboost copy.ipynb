    "# =========================================================\n",
    "# Elegant Visualization (AUTO from variables, labels on Precision bars)\n",
    "# - No manual numbers\n",
    "# - Model names shown above Precision bars\n",
    "# =========================================================\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, roc_auc_score\n",
    "\n",
    "# =========================================================\n",
    "# Hitung skor OTOMATIS dari model yang SUDAH ADA\n",
    "# =========================================================\n",
    "models = [\"XGBoost Tabular\", \"XGBoost + ST\", \"XGBoost + GNN\", \"XGBoost Hybrid (GNN + ST)\"]\n",
    "metrics = [\"Accuracy\", \"Precision\", \"Recall\", \"F1-Score\", \"AUC\"]\n",
    "\n",
    "scores = np.array([\n",
    "    [\n",
    "        accuracy_score(yt_test, y_pred_tab),\n",
    "        precision_score(yt_test, y_pred_tab),\n",
    "        recall_score(yt_test, y_pred_tab),\n",
    "        f1_score(yt_test, y_pred_tab),\n",
    "        roc_auc_score(yt_test, y_prob_tab)\n",
    "    ],\n",
    "    [\n",
