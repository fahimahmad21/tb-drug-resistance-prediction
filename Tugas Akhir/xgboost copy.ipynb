    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "# ================================\n",
    "# 1. Siapkan data\n",
    "# ================================\n",
    "X = combined_features                  # shape (n_samples, 448)\n",
    "y = df[\"label\"].values                 # ground truth\n",
    "indices = np.arange(len(df))           # index asli mutations.csv\n",
    "\n",
    "# ================================\n",
    "# 2. Train-test split + index\n",
    "# ================================\n",
    "X_train, X_test, y_train, y_test, idx_train, idx_test = train_test_split(\n",
    "    X,\n",
    "    y,\n",
    "    indices,\n",
    "    test_size=0.2,\n",
    "    stratify=y,\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "# ================================\n",
    "# 3. DataFrame embedding (X_test)\n",
    "# ================================\n",
    "X_test_df = pd.DataFrame(\n",
    "    X_test,\n",
    "    columns=[f\"feat_{i}\" for i in range(X_test.shape[1])]\n",
    ")\n",
    "\n",
    "# ================================\n",
    "# 4. Metadata dari mutations.csv\n",
    "# ================================\n",
    "meta_df = df.loc[idx_test, [\"Gene\", \"Mutation\", \"drug\", \"confidence\"]].reset_index(drop=True)\n",
    "\n",
    "# ================================\n",
    "# 5. Gabungkan metadata + fitur + label\n",
    "# ================================\n",
    "final_test_df = pd.concat(\n",
    "    [\n",
    "        meta_df,\n",
    "        X_test_df,\n",
    "        pd.Series(y_test, name=\"true_label\")\n",
    "    ],\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "# ================================\n",
    "# 6. Simpan ke CSV\n",
    "# ================================\n",
    "final_test_df.to_csv(\"X_test_with_metadata.csv\", index=False)\n",
    "\n",
    "print(\"âœ… X_test_with_metadata.csv berhasil disimpan.\")\n",
    "print(\"Jumlah data uji:\", len(final_test_df))\n"
   ]
