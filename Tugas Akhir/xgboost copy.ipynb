    "        try:\n",
    "            # NetworkX 3.x (struktur submodul berubah)\n",
    "            from networkx.readwrite.gpickle import write_gpickle\n",
    "            write_gpickle(G, path)\n",
    "            print(f\"âœ… Graph disimpan dengan write_gpickle (3.x API): {path}\")\n",
    "            return\n",
    "        except Exception as e2:\n",
    "            # Fallback terakhir pakai pickle standar\n",
    "            with open(path, \"wb\") as f:\n",
    "                pickle.dump(G, f, protocol=pickle.HIGHEST_PROTOCOL)\n",
    "            print(f\"âš ï¸ Graph disimpan dengan pickle standar (fallback): {path}\")\n",
    "            print(\"   NetworkX write_gpickle gagal dengan error:\", e1, \"|\", e2)\n",
    "\n",
    "# ---- SIMPAN GRAPH ----\n",
    "save_graph_compat(G, \"graph.pkl\")\n",
    "\n",
    "# ---- SIMPAN MAPPING NODE -> INDEX ----\n",
    "node_list = list(G.nodes())\n",
    "node_index = {str(n): i for i, n in enumerate(node_list)}\n",
    "\n",
    "# Tambahkan metadata supaya mudah load di masa depan\n",
    "graph_metadata = {\n",
    "    \"node_index\": node_index,\n",
    "    \"node_count\": len(node_list),\n",
    "    \"timestamp\": datetime.now().isoformat(),\n",
    "    \"graph_file\": \"graph.pkl\",\n",
    "}\n",
    "\n",
    "joblib.dump(graph_metadata, \"graph_index.joblib\")\n",
    "print(f\"âœ… Graph index tersimpan: {len(node_index)} node â†’ graph_index.joblib\")\n",
    "\n",
    "# ---- OPSIONAL: Simpan juga embedding hasil GNN (jika sudah tersedia) ----\n",
    "if 'all_emb' in globals():\n",
    "    np.save(\"node_embeddings.npy\", all_emb)\n",
    "    print(f\"âœ… Node embeddings disimpan: {all_emb.shape} â†’ node_embeddings.npy\")\n",
    "else:\n",
    "    print(\"â„¹ï¸ Variabel all_emb belum tersedia, lewati penyimpanan embedding.\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "âœ… Graph & node index tersimpan: graph.pkl, graph_index.joblib\n"
     ]
    }
   ],
   "source": [
    "# --- SIMPAN GRAPH & INDEX NODE UNTUK INFERENCE (KOMPATIBLE) ---\n",
    "import joblib\n",
    "import networkx as nx\n",
    "\n",
    "def save_graph_compat(G, path=\"graph.pkl\"):\n",
    "    # 1) Coba API lama (NetworkX 2.x): nx.write_gpickle\n",
    "    try:\n",
    "        nx.write_gpickle(G, path)\n",
    "        return\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "    # 2) Coba API baru (submodul di 3.x): networkx.readwrite.gpickle.write_gpickle\n",
    "    try:\n",
    "        from networkx.readwrite.gpickle import write_gpickle\n",
    "        write_gpickle(G, path)\n",
    "        return\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "    # 3) Fallback: pickle standar Python\n",
    "    import pickle\n",
    "    with open(path, \"wb\") as f:\n",
    "        pickle.dump(G, f, protocol=pickle.HIGHEST_PROTOCOL)\n",
    "\n",
    "# ---- SIMPAN ----\n",
    "save_graph_compat(G, \"graph.pkl\")\n",
    "\n",
    "# buat mapping index node sesuai urutan saat ke PyG\n",
    "node_list = list(G.nodes())\n",
    "node_index = {n: i for i, n in enumerate(node_list)}\n",
    "joblib.dump({\"node_index\": node_index}, \"graph_index.joblib\")\n",
    "\n",
    "print(\"âœ… Graph & node index tersimpan: graph.pkl, graph_index.joblib\")\n"
   ]
  },
