    "import json\n",
    "\n",
    "class HybridWithoutGraphRAG:\n",
    "    \"\"\"\n",
    "    Wrapper untuk model Hybrid GNN + XGBoost TANPA explanation GraphRAG.\n",
    "    Ini cuma membungkus xgb_clf kamu.\n",
    "    \"\"\"\n",
    "    def __init__(self, base_model):\n",
    "        self.base_model = base_model\n",
    "\n",
    "    def predict(self, X):\n",
    "        return self.base_model.predict(X)\n",
    "\n",
    "    def predict_proba(self, X):\n",
    "        return self.base_model.predict_proba(X)\n",
    "\n",
    "\n",
    "class HybridWithGraphRAG(HybridWithoutGraphRAG):\n",
    "    \"\"\"\n",
    "    Wrapper untuk model Hybrid + GraphRAG (Full).\n",
    "    Prediksinya sama persis dengan base_model, tapi punya method explain()\n",
    "    yang menjalankan pipeline GraphRAG yang sudah kamu tulis.\n",
    "    \"\"\"\n",
    "    def __init__(self, base_model, graph, llm, top_k=2):\n",
    "        super().__init__(base_model)\n",
    "        self.G = graph\n",
    "        self.llm = llm\n",
    "        self.top_k = top_k\n",
    "\n",
    "    def get_graph_context(self, mutation, gene, drug):\n",
    "        context = []\n",
    "        for node in [mutation, gene, drug]:\n",
    "            if node in self.G:\n",
    "                # deskripsi node\n",
    "                if \"description\" in self.G.nodes[node]:\n",
    "                    context.append(self.G.nodes[node][\"description\"])\n",
    "                # neighbor\n",
    "                neighbors = list(self.G.successors(node))[:self.top_k]\n",
    "                for n in neighbors:\n",
    "                    if \"description\" in self.G.nodes[n]:\n",
    "                        context.append(self.G.nodes[n][\"description\"])\n",
    "        return \"\\n\".join(context)\n",
    "\n",
    "    def explain_row(self, row):\n",
    "        \"\"\"\n",
    "        row: satu baris pandas (punya kolom Mutation, Gene, drug,\n",
    "             Predicted_Class, Predicted_Prob, text optional)\n",
    "        return: dict explanation (JSON) atau raw_text\n",
    "        \"\"\"\n",
    "        pred_class = int(row[\"Predicted_Class\"])\n",
    "        pred_prob = float(row[\"Predicted_Prob\"])\n",
    "        features = {\n",
    "            \"Mutation\": row[\"Mutation\"],\n",
    "            \"Gene\": row[\"Gene\"],\n",
    "            \"Drug\": row[\"drug\"],\n",
    "        }\n",
    "        rag_context = self.get_graph_context(row[\"Mutation\"], row[\"Gene\"], row[\"drug\"])\n",
    "\n",
    "        prompt = f\"\"\"\n",
    "Anda adalah asisten bioinformatika yang menjelaskan hasil prediksi resistensi obat TB\n",
    "berdasarkan model GNN + XGBoost + Knowledge Graph (GraphRAG).\n",
    "\n",
    "Data input:\n",
    "{json.dumps(features, indent=2)}\n",
    "Predicted_Class: {pred_class}\n",
    "Predicted_Prob: {pred_prob:.4f}\n",
    "\n",
    "Konteks biologis graf:\n",
    "{rag_context}\n",
    "\n",
    "Berikan penjelasan dalam format JSON berikut:\n",
    "{{\n",
    "  \"Interpretasi_prediksi\": \"...\",\n",
    "  \"Makna_biologis\": \"...\",\n",
    "  \"Insight_knowledge_graph\": \"...\",\n",
    "  \"Kesimpulan\": \"...\",\n",
    "}}\n",
    "\"\"\"\n",
    "        response = self.llm.generate([[HumanMessage(content=prompt)]])\n",
    "        text = (\n",
    "            response.generations[0][0]\n",
    "            .text.strip()\n",
    "            .replace(\"```json\", \"\")\n",
    "            .replace(\"```\", \"\")\n",
    "        )\n",
    "        try:\n",
    "            explanation_json = json.loads(text)\n",
    "        except Exception:\n",
    "            explanation_json = {\"raw_text\": text}\n",
    "        return explanation_json\n",
    "\n",
    "    def explain_batch(self, df, max_samples=10):\n",
    "        \"\"\"\n",
    "        Jalankan explanation untuk beberapa contoh (misal 10)\n",
    "        yang nanti bisa kamu tampilkan di BAB hasil.\n",
    "        \"\"\"\n",
    "        explanations = []\n",
    "        subset = df.head(max_samples)\n",
    "        for _, row in subset.iterrows():\n",
    "            exp = self.explain_row(row)\n",
    "            explanations.append(exp)\n",
    "        return subset.reset_index(drop=True), explanations\n"
   ]
  },
