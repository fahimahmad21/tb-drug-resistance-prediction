    "import time\n",
    "import pandas as pd\n",
    "\n",
    "results = []\n",
    "\n",
    "def measure_inference_time(model, X, model_name, n_repeat=5):\n",
    "    times = []\n",
    "    for _ in range(n_repeat):\n",
    "        start = time.perf_counter()\n",
    "        _ = model.predict(X)\n",
    "        end = time.perf_counter()\n",
    "        times.append(end - start)\n",
    "    \n",
    "    return {\n",
    "        \"Model\": model_name,\n",
    "        \"Rata-rata Waktu Inferensi (detik)\": round(sum(times)/len(times), 4)\n",
    "    }\n",
    "\n",
    "# Contoh pemanggilan (sesuaikan dengan model & data kamu)\n",
    "results.append(measure_inference_time(xgb_tabular, Xt_test, \"XGBoost Tabular\"))\n",
    "results.append(measure_inference_time(xgb_baseline, Xb_test, \"XGBoost + ST\"))\n",
    "results.append(measure_inference_time(xgb_gnn, Xg_test, \"XGBoost + GNN\"))\n",
    "results.append(measure_inference_time(xgb_clf, X_test, \"Hybrid (ST + GNN)\"))\n",
    "\n",
    "df_time = pd.DataFrame(results)\n",
    "df_time\n"
   ]
