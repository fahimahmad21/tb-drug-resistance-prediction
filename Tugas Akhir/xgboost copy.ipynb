    "# --- KONVERSI graph.pkl -> graph.json (JSON-friendly) ---\n",
    "import json\n",
    "\n",
    "def save_graph_as_json(G, json_path=\"graph.json\"):\n",
    "    data = {\n",
    "        \"nodes\": [\n",
    "            {\n",
    "                \"id\": str(n),\n",
    "                \"type\": G.nodes[n].get(\"type\", \"\"),\n",
    "                \"description\": G.nodes[n].get(\"description\", \"\")\n",
    "            }\n",
    "            for n in G.nodes()\n",
    "        ],\n",
    "        \"edges\": [\n",
    "            {\n",
    "                \"source\": str(u),\n",
    "                \"target\": str(v),\n",
    "                \"relation\": G.edges[u, v].get(\"relation\", \"\")\n",
    "            }\n",
    "            for u, v in G.edges()\n",
    "        ]\n",
    "    }\n",
    "    with open(json_path, \"w\", encoding=\"utf-8\") as f:\n",
    "        json.dump(data, f, ensure_ascii=False, indent=2)\n",
    "    print(f\"âœ… Graph JSON tersimpan ke: {json_path} | Nodes: {len(G.nodes())}, Edges: {len(G.edges())}\")\n",
    "\n",
    "# Jalankan fungsi konversi\n",
    "save_graph_as_json(G, \"graph.json\")\n"
   ]
