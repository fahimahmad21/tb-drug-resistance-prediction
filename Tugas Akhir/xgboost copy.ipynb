    "        roc_auc_score(yb_test, y_test_prob)\n",
    "    ],\n",
    "    [\n",
    "        accuracy_score(yg_test, y_pred_gnn),\n",
    "        precision_score(yg_test, y_pred_gnn),\n",
    "        recall_score(yg_test, y_pred_gnn),\n",
    "        f1_score(yg_test, y_pred_gnn),\n",
    "        roc_auc_score(yg_test, y_prob_gnn)\n",
    "    ],\n",
    "    [\n",
    "        accuracy_score(y_test, y_pred),\n",
    "        precision_score(y_test, y_pred),\n",
    "        recall_score(y_test, y_pred),\n",
