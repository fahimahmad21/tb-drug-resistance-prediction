    "def build_graphrag_prompt(row):\n",
    "    return f\"\"\"\n",
    "Predicted probability: {row['y_prob']}\n",
    "Final quadrant: {row['Final_Quadrant']}\n",
    "Graph evidence available: {row['Has_Graph_Evidence']}\n",
    "\n",
    "Explain the prediction conservatively.\n",
    "\"\"\"\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 353,
   "metadata": {},
   "outputs": [],
   "source": [
    "def graphrag_with_llm(row):\n",
    "    prompt = build_graphrag_prompt(row)\n",
    "    \n",
    "    response = client.chat.completions.create(\n",
    "        model=\"llama-3.1-8b-instant\",  # paling stabil di free tier\n",
    "        messages=[\n",
    "            {\"role\": \"system\", \"content\": \"You are a conservative medical AI assistant.\"},\n",
    "            {\"role\": \"user\", \"content\": prompt}\n",
    "        ],\n",
    "        temperature=0.2\n",
    "    )\n",
    "    \n",
    "    return response.choices[0].message.content\n"
   ]
