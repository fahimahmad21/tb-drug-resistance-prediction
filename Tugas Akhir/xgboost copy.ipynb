    "GRAPH CONTEXT UNTUK REASONING"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 202,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_graph_context(mutation, gene, drug, top_k=3):\n",
    "    context = []\n",
    "\n",
    "    for node in [mutation, gene, drug]:\n",
    "        if node in G:\n",
    "            node_data = G.nodes[node]\n",
    "\n",
    "            # ambil deskripsi jika ada\n",
    "            if \"description\" in node_data:\n",
    "                context.append(node_data[\"description\"])\n",
    "            else:\n",
    "                # fallback yang masih ilmiah\n",
    "                context.append(\n",
    "                    f\"Node {node} bertipe {node_data.get('type', 'unknown')} \"\n",
    "                    f\"dalam biomedical knowledge graph.\"\n",
    "                )\n",
    "\n",
    "            # ambil relasi tetangga\n",
    "            neighbors = list(G.successors(node))[:top_k]\n",
    "            for n in neighbors:\n",
    "                edge_data = G.get_edge_data(node, n)\n",
    "                rel = edge_data.get(\"relation\", \"related_to\")\n",
    "                context.append(\n",
    "                    f\"{node} {rel} {n}\"\n",
    "                )\n",
    "\n",
    "    # jika konteks kosong\n",
    "    if len(context) == 0:\n",
    "        return \"Tidak ditemukan konteks biologis relevan dalam knowledge graph.\"\n",
    "\n",
    "    return \"\\n\".join(context)\n"
   ]
  },
