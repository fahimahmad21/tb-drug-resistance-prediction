   "source": [
    "def has_graph_evidence(G, mutation, gene, drug):\n",
    "    \"\"\"\n",
    "    Mengecek apakah terdapat relasi eksplisit\n",
    "    Mutation -> Gene -> Drug dalam knowledge graph\n",
    "    \"\"\"\n",
    "    try:\n",
    "        if mutation in G and gene in G and drug in G:\n",
    "            # mutation -> gene\n",
    "            if G.has_edge(mutation, gene):\n",
    "                # gene -> drug\n",
    "                if G.has_edge(gene, drug):\n",
    "                    return True\n",
    "        return False\n",
    "    except:\n",
    "        return False\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 285,
   "metadata": {},
   "outputs": [],
   "source": [
    "# prediksi class & probabilitas\n",
    "df_test[\"Predicted_Prob\"] = xgb_clf.predict_proba(X_test)[:, 1]\n",
    "df_test[\"Predicted_Class\"] = xgb_clf.predict(X_test)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 286,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_test[\"Has_Graph_Evidence\"] = df_test.apply(\n",
    "    lambda r: has_graph_evidence(G, r[\"Mutation\"], r[\"Gene\"], r[\"drug\"]),\n",
    "    axis=1\n",
    ")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 287,
   "metadata": {},
   "outputs": [],
   "source": [
    "def assign_quadrant_rule_based(pred_prob, has_graph_evidence, threshold=0.5):\n",
    "    \"\"\"\n",
    "    Penentuan kuadran berbasis aturan (NON-LLM)\n",
    "    \"\"\"\n",
    "    if pred_prob >= threshold and has_graph_evidence:\n",
    "        return \"Q1\"\n",
    "    elif pred_prob >= threshold and not has_graph_evidence:\n",
    "        return \"Q2\"\n",
    "    elif pred_prob < threshold and has_graph_evidence:\n",
    "        return \"Q3\"\n",
    "    else:\n",
    "        return \"Q4\"\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 288,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_test[\"Final_Quadrant\"] = df_test.apply(\n",
    "    lambda r: assign_quadrant_rule_based(\n",
    "        r[\"Predicted_Prob\"],\n",
    "        r[\"Has_Graph_Evidence\"]\n",
    "    ),\n",
    "    axis=1\n",
    ")\n"
   ]
  },
