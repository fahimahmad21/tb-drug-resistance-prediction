    "def has_explicit_graph_evidence(mutation, gene, drug, rag_context):\n",
    "    if not isinstance(rag_context, str):\n",
    "        return False\n",
    "\n",
    "    text = rag_context.lower()\n",
    "\n",
    "    mut_gene = f\"mutasi {mutation.lower()} memengaruhi gen {gene.lower()}\"\n",
    "    gene_drug = f\"gen {gene.lower()} berhubungan dengan resistensi terhadap {drug.lower()}\"\n",
    "\n",
    "    return (mut_gene in text) and (gene_drug in text)\n"
   ]
  },
