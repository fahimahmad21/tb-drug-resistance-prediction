    "from sklearn.metrics import (\n",
    "    classification_report,\n",
    "    confusion_matrix,\n",
    "    accuracy_score,\n",
    "    roc_auc_score,\n",
    "    precision_score,\n",
    "    recall_score,\n",
    "    f1_score\n",
    ")\n",
    "import numpy as np\n",
    "\n",
    "# Evaluasi di data training dan testing\n",
    "y_pred_train = xgb_clf.predict(X_train)\n",
    "y_pred_test = xgb_clf.predict(X_test)\n",
    "\n",
    "y_proba_train = xgb_clf.predict_proba(X_train)[:, 1]\n",
    "y_proba_test = xgb_clf.predict_proba(X_test)[:, 1]\n",
    "\n",
    "# 1ï¸âƒ£ Akurasi di train dan test (indikasi underfitting/overfitting)\n",
    "train_acc = accuracy_score(y_train, y_pred_train)\n",
    "test_acc = accuracy_score(y_test, y_pred_test)\n",
    "\n",
    "print(\"=== Evaluasi Overfitting / Underfitting ===\")\n",
    "print(f\"Akurasi Training : {train_acc:.4f}\")\n",
    "print(f\"Akurasi Testing  : {test_acc:.4f}\")\n",
    "\n",
    "if abs(train_acc - test_acc) < 0.03:\n",
    "    print(\"âœ… Model stabil â€” tidak overfitting atau underfitting.\")\n",
    "elif train_acc > test_acc:\n",
    "    print(\"âš ï¸ Model sedikit overfitting (performa train lebih tinggi).\")\n",
    "else:\n",
    "    print(\"âš ï¸ Model underfitting (performa train terlalu rendah).\")\n",
    "\n",
    "# 2ï¸âƒ£ Distribusi prediksi (indikasi bias kelas)\n",
    "unique, counts = np.unique(y_pred_test, return_counts=True)\n",
    "class_dist = dict(zip(unique, counts))\n",
    "print(\"\\n=== Distribusi Prediksi (Keseimbangan Kelas) ===\")\n",
    "print(class_dist)\n",
    "\n",
    "if abs(class_dist.get(0, 0) - class_dist.get(1, 0)) < 0.1 * len(y_test):\n",
    "    print(\"âœ… Prediksi seimbang antara kelas sensitif dan resisten.\")\n",
    "else:\n",
    "    print(\"âš ï¸ Prediksi agak tidak seimbang â€” periksa rasio kelas.\")\n",
    "\n",
    "# 3ï¸âƒ£ Evaluasi bias antar kelas\n",
    "report = classification_report(y_test, y_pred_test, target_names=[\"Sensitif (0)\", \"Resisten (1)\"], output_dict=True)\n",
    "print(\"\\n=== Evaluasi Bias Antar Kelas ===\")\n",
    "for label in [\"Sensitif (0)\", \"Resisten (1)\"]:\n",
    "    prec = report[label][\"precision\"]\n",
    "    rec = report[label][\"recall\"]\n",
    "    f1 = report[label][\"f1-score\"]\n",
    "    print(f\"{label}: Precision={prec:.3f}, Recall={rec:.3f}, F1={f1:.3f}\")\n",
    "\n",
    "if abs(report[\"Sensitif (0)\"][\"f1-score\"] - report[\"Resisten (1)\"][\"f1-score\"]) < 0.1:\n",
    "    print(\"âœ… Tidak ada bias signifikan antar kelas.\")\n",
    "else:\n",
    "    print(\"âš ï¸ Ada sedikit bias â€” salah satu kelas diprediksi lebih baik dari yang lain.\")\n",
    "\n",
    "# 4ï¸âƒ£ Skor AUC (indikasi kemampuan model memisahkan kelas)\n",
