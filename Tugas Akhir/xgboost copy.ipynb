   "source": [
    "# ===== Perbaikan: ambil graph embeddings per-node dan bangun graph_emb untuk setiap baris df =====\n",
    "import numpy as np\n",
    "import torch\n",
    "from sentence_transformers import SentenceTransformer\n",
    "\n",
    "# pastikan device & model GNN di device yang sama\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "gnn.to(device)\n",
    "data.x = data.x.to(device)\n",
    "data.edge_index = data.edge_index.to(device)\n",
    "\n",
    "# 1) Ekstrak semua node embeddings dari GNN (embedding 'x' dari forward)\n",
    "gnn.eval()\n",
    "with torch.no_grad():\n",
    "    out = gnn(data.x, data.edge_index)   # return (x, logits) sesuai definisimu\n",
    "# ambil embedding node (index 0 dari output)\n",
    "if isinstance(out, (tuple, list)):\n",
    "    all_emb = out[0].cpu().numpy()\n",
    "else:\n",
    "    all_emb = out.cpu().numpy()\n",
    "\n",
    "print(\"all_emb shape:\", all_emb.shape)   # misal (num_nodes, 64)\n",
    "emb_dim = all_emb.shape[1]\n",
    "\n",
    "# 2) Ambil node_list dari G (kamu membuat G sebelumnya)\n",
    "try:\n",
    "    node_list = list(G.nodes())\n",
    "    print(\"node_list length:\", len(node_list))\n",
    "except Exception as e:\n",
    "    # fallback: buat indeks string (hanya jika kamu tahu urutan sama)\n",
    "    node_list = [str(i) for i in range(all_emb.shape[0])]\n",
    "    print(\"Warning: G tidak ditemukan. node_list dibuat dari indeks string.\", e)\n",
    "\n",
    "# cek konsistensi\n",
    "if len(node_list) != all_emb.shape[0]:\n",
    "    print(\"Peringatan: len(node_list) != jumlah embedding. Pastikan node_list urut sama waktu pembuatan graph.\")\n",
    "else:\n",
    "    print(\"node_list konsisten dengan all_emb.\")\n",
    "\n",
    "# 3) Buat mapping node -> embedding (jaga beberapa variasi key untuk robustness)\n",
    "def normalize_key(s):\n",
    "    if s is None:\n",
    "        return None\n",
    "    s = str(s)\n",
    "    s_strip = s.strip()\n",
    "    variants = [\n",
    "        s_strip,                        # original\n",
    "        s_strip.replace(\" \", \"_\"),      # spaces -> underscore\n",
    "        s_strip.replace(\"_\", \" \"),      # underscore -> space\n",
    "        s_strip.lower(),                # lowercase\n",
    "        s_strip.lower().replace(\" \", \"_\"),\n",
    "        s_strip.lower().replace(\"_\", \" \"),\n",
    "    ]\n",
    "    # remove duplicates while preserving order\n",
    "    seen = set(); uniq = []\n",
    "    for v in variants:\n",
    "        if v not in seen:\n",
    "            uniq.append(v); seen.add(v)\n",
    "    return uniq\n",
    "\n",
    "node_to_emb = {}\n",
    "for i, n in enumerate(node_list):\n",
    "    node_to_emb[str(n)] = all_emb[i]\n",
    "    # also store normalized variants to increase match chance\n",
    "    for v in normalize_key(n) or []:\n",
    "        if v not in node_to_emb:\n",
    "            node_to_emb[v] = all_emb[i]\n",
    "\n",
    "# 4) Fungsi ambil embedding untuk row: cek mut, gene, drug, lalu avg (atau fallback 0-vector)\n",
    "def get_graph_emb_for_row_avg(row):\n",
    "    # coba berbagai key forms untuk tiap node\n",
    "    mut = row.get(\"Mutation\")\n",
    "    gene = row.get(\"Gene\")\n",
    "    drug = row.get(\"drug\")  # pastikan nama kolom sama\n",
    "    # helper cek variants\n",
    "    def find_emb(key):\n",
    "        if key is None:\n",
    "            return None\n",
    "        # langsung cek beberapa varian\n",
    "        for cand in normalize_key(key):\n",
    "            if cand in node_to_emb:\n",
    "                return node_to_emb[cand]\n",
    "        # try raw as fallback\n",
    "        if str(key) in node_to_emb:\n",
    "            return node_to_emb[str(key)]\n",
    "        return None\n",
    "\n",
    "    emb_mut = find_emb(mut)\n",
    "    emb_gene = find_emb(gene)\n",
    "    emb_drug = find_emb(drug)\n",
    "\n",
    "    # jika salah satu None, ganti dengan zero vector supaya average tetap berjalan\n",
    "    if emb_mut is None:\n",
    "        emb_mut = np.zeros(emb_dim, dtype=float)\n",
    "    if emb_gene is None:\n",
    "        emb_gene = np.zeros(emb_dim, dtype=float)\n",
    "    if emb_drug is None:\n",
    "        emb_drug = np.zeros(emb_dim, dtype=float)\n",
    "\n",
    "    # strategi: rata-rata tiga embedding -> menghasilkan 1 x emb_dim\n",
    "    return np.mean([emb_mut, emb_gene, emb_drug], axis=0)\n",
    "\n",
    "# 5) Bangun graph_emb matrix sesuai jumlah baris df\n",
    "graph_emb_rows = [get_graph_emb_for_row_avg(r) for _, r in df.iterrows()]\n",
    "graph_emb = np.vstack(graph_emb_rows)   # shape (len(df), emb_dim)\n",
    "print(\"Graph embedding shape (final):\", graph_emb.shape)\n",
    "\n",
    "# ===== Semantic embedding (kamu sudah pakai model ini; dipertahankan) =====\n",
    "model_sem = SentenceTransformer(\"all-MiniLM-L6-v2\")\n",
    "df[\"text\"] = df[\"Gene\"] + \" \" + df[\"Mutation\"] + \" \" + df[\"drug\"]\n",
    "semantic_emb = model_sem.encode(df[\"text\"].tolist(), show_progress_bar=True)\n",
    "print(\"Semantic embedding shape:\", semantic_emb.shape)\n",
    "\n",
    "# ===== Gabungkan fitur dengan benar (tanpa np.resize) =====\n",
    "combined_features = np.concatenate([semantic_emb, graph_emb], axis=1)\n",
    "print(\"Combined features shape:\", combined_features.shape)\n",
    "\n",
    "# ===== Split data (sama seperti sebelumnya) =====\n",
    "from sklearn.model_selection import train_test_split\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    combined_features, df[\"label\"], test_size=0.2, stratify=df[\"label\"], random_state=42\n",
    ")\n",
    "\n",
    "print(\"Shapes -> X_train:\", X_train.shape, \"X_test:\", X_test.shape)\n"
   ]
  },
