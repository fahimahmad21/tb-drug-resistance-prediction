   "source": [
    "# === Prediksi data baru (tanpa np.resize) ===\n",
    "import numpy as np\n",
    "\n",
    "# 1ï¸âƒ£ Data baru\n",
    "new_data = pd.DataFrame({\n",
    "    \"Mutation\": [\"c.1782C>G\"],\n",
    "    \"Gene\": [\"aftB\"],\n",
    "    \"drug\": [\"ethambutol\"]\n",
    "})\n",
    "new_data[\"text\"] = new_data[\"Gene\"] + \" \" + new_data[\"Mutation\"] + \" \" + new_data[\"drug\"]\n",
    "\n",
    "# 2ï¸âƒ£ Semantic embedding\n",
    "semantic_new = model_sem.encode(new_data[\"text\"].tolist())\n",
    "\n",
    "# 3ï¸âƒ£ Graph embedding lookup berdasarkan node hasil training GNN\n",
    "# Gunakan mapping node_to_emb yang sudah dimuat dari graph (lihat load_graph_for_inference)\n",
    "emb_dim = 64  # karena GNN kamu out_channels=64\n",
    "\n",
    "def normalize_key(s):\n",
    "    if s is None:\n",
    "        return \"\"\n",
    "    return str(s).lower().strip().replace(\"_\", \" \").replace(\"-\", \" \").replace(\".\", \" \").replace(\"  \", \" \")\n",
    "\n",
    "def find_node_emb(name):\n",
    "    \"\"\"Cari embedding node dari node_to_emb (dengan fallback).\"\"\"\n",
    "    if name is None:\n",
    "        return np.zeros(emb_dim)\n",
    "    # cek berbagai variasi nama node\n",
    "    candidates = [name, normalize_key(name), name.lower(), name.replace(\" \", \"_\")]\n",
    "    for c in candidates:\n",
    "        if c in node_to_emb:\n",
    "            return node_to_emb[c]\n",
    "    # fallback: vector nol\n",
    "    return np.zeros(emb_dim)\n",
    "\n",
    "# Ambil embedding mutation, gene, drug â†’ lalu rata-rata (konsisten dengan training)\n",
    "graph_rows = []\n",
    "for _, row in new_data.iterrows():\n",
    "    mut_emb = find_node_emb(row[\"Mutation\"])\n",
    "    gene_emb = find_node_emb(row[\"Gene\"])\n",
    "    drug_emb = find_node_emb(row[\"drug\"])\n",
    "    graph_feat = np.mean([mut_emb, gene_emb, drug_emb], axis=0)\n",
    "    graph_rows.append(graph_feat)\n",
    "\n",
    "graph_emb_new = np.vstack(graph_rows)\n",
    "print(\"Graph embedding shape:\", graph_emb_new.shape)\n",
    "\n",
    "# 4ï¸âƒ£ Gabungkan semantic + graph embeddings\n",
    "X_new = np.concatenate([semantic_new, graph_emb_new], axis=1)\n",
    "print(\"Combined feature shape:\", X_new.shape)\n",
    "\n",
    "# 5ï¸âƒ£ Prediksi dengan XGBoost\n",
    "y_pred = xgb_clf.predict(X_new)\n",
    "y_prob = xgb_clf.predict_proba(X_new)[:, 1]\n",
    "\n",
    "# 6ï¸âƒ£ Tambahkan hasil ke dataframe\n",
    "new_data[\"Predicted_Class\"] = y_pred\n",
    "new_data[\"Predicted_Prob\"] = y_prob\n",
    "print(\"âœ… Prediction result:\")\n",
    "print(new_data)\n"
   ]
