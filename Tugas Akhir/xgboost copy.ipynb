    "import time\n",
    "import pandas as pd\n",
    "\n",
    "# -------------------------------\n",
    "# 1. Fungsi ukur waktu inferensi\n",
    "# -------------------------------\n",
    "def measure_inference_time(model, X, model_name, n_repeat=5):\n",
    "    times = []\n",
    "    for _ in range(n_repeat):\n",
    "        start = time.perf_counter()\n",
    "        _ = model.predict(X)\n",
    "        end = time.perf_counter()\n",
    "        times.append(end - start)\n",
    "\n",
    "    return {\n",
    "        \"Model\": model_name,\n",
    "        \"Rata-rata Waktu (detik)\": round(sum(times) / len(times), 4)\n",
    "    }\n",
    "\n",
    "# -------------------------------\n",
    "# 2. Ukur semua model XGBoost\n",
    "# -------------------------------\n",
    "results = []\n",
    "\n",
    "results.append(measure_inference_time(xgb_tabular, Xt_test, \"XGBoost Tabular\"))\n",
    "results.append(measure_inference_time(xgb_baseline, Xb_test, \"XGBoost + ST\"))\n",
    "results.append(measure_inference_time(xgb_gnn, Xg_test, \"XGBoost + GNN\"))\n",
    "results.append(measure_inference_time(xgb_clf, X_test, \"Hybrid XGBoost (ST + GNN)\"))\n",
    "\n",
    "df_time_models = pd.DataFrame(results)\n",
    "\n",
    "# -------------------------------\n",
    "# 3. Tambahkan GraphRAG (tanpa & dengan LLM)\n",
    "# -------------------------------\n",
    "df_graphrag = pd.DataFrame([\n",
    "    {\n",
    "        \"Model\": \"Hybrid + GraphRAG\",\n",
    "        \"Rata-rata Waktu (detik)\": core_time   # hasil ukur nyata\n",
    "    },\n",
    "    {\n",
    "        \"Model\": \"Hybrid + GraphRAG (LLM - Groq)\",\n",
    "        \"Rata-rata Waktu (detik)\": llm_time    # hasil ukur nyata\n",
    "    }\n",
    "])\n",
    "\n",
    "# -------------------------------\n",
    "# 4. GABUNGKAN SEMUA\n",
    "# -------------------------------\n",
    "df_time_final = pd.concat(\n",
    "    [df_time_models, df_graphrag],\n",
    "    ignore_index=True\n",
    ")\n",
    "\n",
    "df_time_final\n"
   ]
  },
