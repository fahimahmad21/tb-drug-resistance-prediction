   "source": [
    "import pandas as pd\n",
    "\n",
    "# 1. Ambil data error kuadran\n",
    "df_errors = df_eval[\n",
    "    df_eval[\"quadrant_llm\"] != df_eval[\"quadrant_validator\"]\n",
    "].copy()\n",
    "\n",
    "# 2. Mapping kuadran ke skor ordinal\n",
    "quadrant_score = {\n",
    "    \"Q4\": 0,  # risiko terendah\n",
    "    \"Q3\": 1,\n",
    "    \"Q2\": 2,\n",
    "    \"Q1\": 3   # risiko tertinggi\n",
    "}\n",
    "\n",
    "# âš ï¸ Paksa hasil mapping jadi numerik (INI KUNCI FIX ERROR)\n",
    "df_errors[\"score_llm\"] = (\n",
    "    df_errors[\"quadrant_llm\"]\n",
    "    .map(quadrant_score)\n",
    "    .astype(int)\n",
    ")\n",
    "\n",
    "df_errors[\"score_validator\"] = (\n",
    "    df_errors[\"quadrant_validator\"]\n",
    "    .map(quadrant_score)\n",
    "    .astype(int)\n",
    ")\n",
    "\n",
    "# 3. Hitung jarak kesalahan kuadran (severity)\n",
    "df_errors[\"quadrant_distance\"] = (\n",
    "    df_errors[\"score_llm\"] - df_errors[\"score_validator\"]\n",
    ").abs()\n",
    "\n",
    "# 4. Tentukan arah kesalahan\n",
    "df_errors[\"error_direction\"] = df_errors[\"score_llm\"] - df_errors[\"score_validator\"]\n",
    "\n",
    "df_errors[\"error_type\"] = df_errors[\"error_direction\"].apply(\n",
    "    lambda x: \"Over-risk\" if x > 0 else \"Under-risk\"\n",
    ")\n",
    "\n",
    "# 5. Confidence error (seberapa yakin tapi salah)\n",
    "df_errors[\"confidence_error\"] = abs(df_errors[\"y_prob\"] - 0.5)\n",
    "\n",
    "# 6. Ringkasan numerik\n",
    "summary = pd.DataFrame({\n",
    "    \"Jumlah Error\": [len(df_errors)],\n",
    "    \"Rata-rata Jarak Kesalahan\": [round(df_errors[\"quadrant_distance\"].mean(), 2)],\n",
    "    \"Jarak Kesalahan Maksimum\": [df_errors[\"quadrant_distance\"].max()],\n",
    "    \"Over-risk\": [(df_errors[\"error_type\"] == \"Over-risk\").sum()],\n",
    "    \"Under-risk\": [(df_errors[\"error_type\"] == \"Under-risk\").sum()],\n",
    "    \"Rata-rata Confidence Error\": [round(df_errors[\"confidence_error\"].mean(), 3)]\n",
    "})\n",
    "\n",
    "# 7. Output\n",
    "print(\"=== Ringkasan Tingkat Kesalahan Kuadran ===\")\n",
    "print(summary)\n",
    "\n",
    "print(\"\\n=== Distribusi Jarak Kesalahan ===\")\n",
    "print(df_errors[\"quadrant_distance\"].value_counts().sort_index())\n",
    "\n",
    "print(\"\\n=== Distribusi Arah Kesalahan ===\")\n",
    "print(df_errors[\"error_type\"].value_counts())\n",
    "\n",
    "print(\"\\n=== Contoh Error (5 data pertama) ===\")\n",
    "print(\n",
    "    df_errors[[\n",
    "        \"Mutation\", \"Gene\", \"drug\", \"y_prob\",\n",
    "        \"quadrant_llm\", \"quadrant_validator\",\n",
    "        \"quadrant_distance\", \"error_type\"\n",
    "    ]].head()\n",
    ")\n"
   ]
