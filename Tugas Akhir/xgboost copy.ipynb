    "def determine_quadrant(prob, evidence):\n",
    "    if prob >= 0.5 and evidence:\n",
    "        return \"Q1\"\n",
    "    if prob >= 0.5 and not evidence:\n",
    "        return \"Q2\"\n",
    "    if prob < 0.5 and evidence:\n",
    "        return \"Q3\"\n",
    "    return \"Q4\"\n"
   ]
