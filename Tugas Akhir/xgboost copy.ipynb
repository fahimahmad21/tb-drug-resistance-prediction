    "def evaluasi_sederhana(y_true, y_pred, nama_model):\n",
    "    correct = (y_pred == y_true).sum()\n",
    "    total = len(y_true)\n",
    "\n",
    "    print(f\"=== {nama_model} ===\")\n",
    "    print(\"Total data uji :\", total)\n",
    "    print(\"Prediksi benar:\", correct)\n",
    "    print(\"Prediksi salah:\", total - correct)\n",
    "    print(\"Akurasi       :\", round(correct / total, 4))\n",
    "    print()\n"
   ]
