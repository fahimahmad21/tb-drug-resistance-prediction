    "\n",
    "import numpy as np\n",
    "import xgboost as xgb\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import accuracy_score, roc_auc_score, classification_report\n",
    "\n",
    "# =================================================\n",
    "# 1. Gunakan graph embedding saja (hasil GNN)\n",
    "# =================================================\n",
    "# graph_emb sudah kamu bangun sebelumnya\n",
    "# shape: (n_samples, emb_dim) -> misal (14338, 64)\n",
    "\n",
    "X_gnn = graph_emb\n",
    "y = df[\"label\"].values\n",
    "\n",
    "print(\"Graph embedding shape:\", X_gnn.shape)\n",
    "print(\"Label shape:\", y.shape)\n",
    "\n",
    "# =================================================\n",
    "# 2. Split data (stratified)\n",
    "# =================================================\n",
    "Xg_train, Xg_test, yg_train, yg_test = train_test_split(\n",
    "    X_gnn,\n",
    "    y,\n",
    "    test_size=0.2,\n",
    "    stratify=y,\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "print(\"Train shape:\", Xg_train.shape)\n",
    "print(\"Test shape :\", Xg_test.shape)\n",
    "\n",
    "# =================================================\n",
    "# 3. Hitung scale_pos_weight (imbalanced class)\n",
    "# =================================================\n",
    "scale_gnn = (yg_train == 0).sum() / (yg_train == 1).sum()\n",
    "print(\"scale_pos_weight:\", scale_gnn)\n",
    "\n",
    "# =================================================\n",
    "# 4. Definisikan XGBoost + GNN\n",
    "# =================================================\n",
    "xgb_gnn = xgb.XGBClassifier(\n",
    "    n_estimators=200,\n",
    "    max_depth=6,\n",
    "    learning_rate=0.05,\n",
    "    subsample=0.8,\n",
    "    colsample_bytree=0.8,\n",
    "    eval_metric=\"logloss\",\n",
    "    random_state=42,\n",
    "    scale_pos_weight=scale_gnn\n",
    ")\n",
    "\n",
    "# =================================================\n",
    "# 5. Training\n",
    "# =================================================\n",
    "xgb_gnn.fit(Xg_train, yg_train)\n",
    "print(\"âœ… XGBoost + GNN training selesai\")\n",
    "\n",
    "# =================================================\n",
    "# 6. Evaluasi\n",
    "# =================================================\n",
    "y_pred_gnn = xgb_gnn.predict(Xg_test)\n",
    "y_prob_gnn = xgb_gnn.predict_proba(Xg_test)[:, 1]\n",
    "\n",
    "print(\"\\n=== XGBoost + GNN (No ST) ===\")\n",
    "print(\"Accuracy:\", accuracy_score(yg_test, y_pred_gnn))\n",
    "print(\"AUC:\", roc_auc_score(yg_test, y_prob_gnn))\n",
    "print(classification_report(yg_test, y_pred_gnn, digits=3))\n",
    "\n",
    "\n"
   ]
